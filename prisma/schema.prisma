generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Справочники автомобилей ────────────────────────────────────────────────

model Brand {
  id        String @id @default(cuid())
  name      String
  slug      String @unique
  logo      String?
  sortOrder Int    @default(0)

  carModels     CarModel[]
  productBrands ProductBrand[]
}

model CarModel {
  id       String @id @default(cuid())
  brandId  String
  name     String
  slug     String @unique
  yearFrom Int?
  yearTo   Int?

  brand           Brand                  @relation(fields: [brandId], references: [id])
  compatibilities ProductCompatibility[]

  @@index([brandId])
}

// ─── Дерево категорий ───────────────────────────────────────────────────────

model Category {
  id          String  @id @default(cuid())
  parentId    String?
  path        String  // materialized path: "/rootId/childId/thisId"
  level       Int     // 0 = корень, 1 = раздел, 2+ = лист
  name        String
  slug        String  @unique
  description String?
  image       String?
  sortOrder   Int     @default(0)

  parent     Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]          @relation("CategoryTree")
  attributes AttributeDefinition[]
  products   Product[]

  @@index([parentId])
  @@index([path])
  @@index([level])
}

// ─── Атрибуты (динамические характеристики для фильтрации) ──────────────────

model AttributeDefinition {
  id         String              @id @default(cuid())
  categoryId String
  name       String
  unit       String?
  filterType AttributeFilterType
  sortOrder  Int                 @default(0)

  category Category          @relation(fields: [categoryId], references: [id])
  values   ProductAttribute[]

  @@index([categoryId])
}

enum AttributeFilterType {
  SELECT
  MULTISELECT
  RANGE
  BOOLEAN
}

// ─── Товары ─────────────────────────────────────────────────────────────────

model Product {
  id             String    @id @default(cuid())
  article        String    @unique
  name           String
  slug           String    @unique
  description    String?
  categoryId     String
  priceRetail    Decimal   @db.Decimal(12, 2)
  priceWholesale Decimal?  @db.Decimal(12, 2)
  stock          Int       @default(0)
  isActive       Boolean   @default(true)
  isOrderable    Boolean   @default(false)
  weight         Float?

  // Поля для будущих интеграций (1С, API поставщика, CSV, другие системы)
  externalId     String?   @unique  // ID товара во внешней системе для upsert
  source         String?            // "1c" | "supplier_api" | "csv" | "manual"
  syncedAt       DateTime?          // дата последней синхронизации из внешнего источника

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category        Category               @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  attributes      ProductAttribute[]
  brands          ProductBrand[]
  compatibilities ProductCompatibility[]
  orderItems      OrderItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([isActive, categoryId])
  @@index([isActive, priceRetail])
  @@index([externalId])
  @@index([syncedAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductAttribute {
  id           String   @id @default(cuid())
  productId    String
  definitionId String
  valueString  String?
  valueNumber  Decimal? @db.Decimal(12, 4)

  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition AttributeDefinition @relation(fields: [definitionId], references: [id])

  @@unique([productId, definitionId])
  @@index([definitionId, valueString])
  @@index([definitionId, valueNumber])
}

model ProductBrand {
  productId String
  brandId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  brand   Brand   @relation(fields: [brandId], references: [id])

  @@id([productId, brandId])
  @@index([brandId])
  @@index([brandId, productId])
}

model ProductCompatibility {
  id         String  @id @default(cuid())
  productId  String
  carModelId String
  yearFrom   Int?
  yearTo     Int?
  note       String?

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  carModel CarModel @relation(fields: [carModelId], references: [id])

  @@unique([productId, carModelId])
  @@index([carModelId, productId])
}

// ─── Пользователи (NextAuth) ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  orders   Order[]
  reviews  Review[]
  bookings Booking[]
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Заказы ─────────────────────────────────────────────────────────────────

model Order {
  id        String      @id @default(cuid())
  userId    String
  total     Decimal     @db.Decimal(12, 2)
  status    OrderStatus @default(PENDING)
  comment   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

// ─── Сервис ─────────────────────────────────────────────────────────────────

model Booking {
  id        String        @id @default(cuid())
  userId    String?
  name      String
  phone     String
  carBrand  String?
  carModel  String?
  carYear   Int?
  service   String
  date      DateTime
  status    BookingStatus @default(PENDING)
  comment   String?
  createdAt DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([date])
}

// ─── Контент ─────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  text      String
  rating    Int
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([approved])
}

model Article {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  body        String
  excerpt     String?
  image       String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
